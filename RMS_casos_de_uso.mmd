graph TB
    %% --- ESTILOS DE ACTORES (Simulación UML) ---
    classDef actor fill:#eceff1,stroke:#37474f,stroke-width:2px,font-weight:bold;

    %% --- BLOQUE GENERAL Y ACCESO ---
    subgraph SistemaGeneral["⚙️ Módulo: Acceso y Sistema"]
        AdminGen["👤 Admin"]:::actor
        CajeroGen["👤 Cajero"]:::actor
        
        UC19(["Iniciar Sesión"])
        UC20(["Cerrar Sesión"])
        UC21(["Ver Dashboard"])
        UC22(["Gestionar Perfil"])
        UC23(["Cambiar Idioma"])
        UC24(["Ver Auditoría"])

        AdminGen --- UC19 & UC20 & UC21 & UC22 & UC23 & UC24
        CajeroGen --- UC19 & UC20 & UC21
    end

    %% --- BLOQUE OPERACIONES VENTA ---
    subgraph ModuloPOS["🛒 Módulo: Punto de Venta (POS)"]
        AdminPOS["👤 Admin"]:::actor
        CajeroPOS["👤 Cajero"]:::actor
        ClientePOS["👤 Cliente"]:::actor

        UC1(["Tomar Orden"])
        UC2(["Procesar Pago"])
        UC3(["Seleccionar Método"])
        UC4(["Agregar Cliente"])

        AdminPOS & CajeroPOS & ClientePOS --- UC1
        AdminPOS & CajeroPOS --- UC2 & UC3 & UC4
    end

    %% --- BLOQUE LOGÍSTICA ---
    subgraph ModuloInventario["📦 Módulo: Inventario y Compras"]
        AdminInv["👤 Admin"]:::actor
        CajeroInv["👤 Cajero"]:::actor
        ProveedorInv["👤 Proveedor"]:::actor

        UC5(["Ver Stock"])
        UC6(["Agregar Item"])
        UC7(["Editar Item"])
        UC8(["Ajustar Cantidad"])
        UC9(["Registrar Compra"])
        UC10(["Ver Historial"])

        AdminInv --- UC5 & UC6 & UC7 & UC8 & UC9 & UC10
        CajeroInv --- UC5
        ProveedorInv --- UC9
    end

    %% --- BLOQUE ADMINISTRACIÓN DE CONTENIDO ---
    subgraph ModuloMenu["🍳 Módulo: Gestión del Menú"]
        AdminMenu["👤 Admin"]:::actor

        UC11(["Agregar Plato"])
        UC12(["Editar Plato"])
        UC13(["Cambiar Disponibilidad"])

        AdminMenu --- UC11 & UC12 & UC13
    end

    %% --- BLOQUE CLIENTES Y FINANZAS ---
    subgraph ModuloClientesGastos["👥 Módulo: Clientes e Indicadores"]
        AdminCli["👤 Admin"]:::actor
        ClienteCli["👤 Cliente"]:::actor

        UC14(["Registrar Cliente"])
        UC15(["Ver Clientes"])
        UC16(["Ver Historial Órdenes"])
        UC17(["Registrar Gasto"])
        UC18(["Ver Reportes"])

        AdminCli --- UC14 & UC15 & UC16 & UC17 & UC18
        ClienteCli --- UC16
    end

    %% --- AJUSTES COSMÉTICOS ---
    style SistemaGeneral fill:#fafafa,stroke:#ccc,stroke-width:1px
    style ModuloPOS fill:#fafafa,stroke:#ccc,stroke-width:1px
    style ModuloInventario fill:#fafafa,stroke:#ccc,stroke-width:1px
    style ModuloMenu fill:#fafafa,stroke:#ccc,stroke-width:1px
    style ModuloClientesGastos fill:#fafafa,stroke:#ccc,stroke-width:1px