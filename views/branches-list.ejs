<%- include('header') -%>

<div class="page-wrapper">
    <div class="content">
        <div class="page-header">
            <div class="page-title">
                <h4 data-i18n="list.branches_title">Branches List</h4>
                <h6 data-i18n="list.branches_sub">Manage your branches</h6>
            </div>
            <div class="page-btn">
                <a href="/add-branch" class="btn btn-added">
                    <img src="assets/img/icons/plus.svg" alt="img" class="me-1">Add New Branch
                </a>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="table-top">
                    <div class="search-set">
                        <div class="search-path">
                            <a class="btn btn-filter" id="filter_search">
                                <img src="assets/img/icons/filter.svg" alt="img">
                                <span><img src="assets/img/icons/closes.svg" alt="img"></span>
                            </a>
                        </div>
                        <div class="search-input">
                            <a class="btn btn-searchset">
                                <img src="assets/img/icons/search-white.svg" alt="img">
                            </a>
                        </div>
                    </div>
                    <div class="wordset">
                        <ul>
                            <li>
                                <a data-bs-toggle="tooltip" data-bs-placement="top" title="pdf" href="/export/branches/pdf">
                                    <img src="assets/img/icons/pdf.svg" alt="img">
                                </a>
                            </li>
                            <li>
                                <a data-bs-toggle="tooltip" data-bs-placement="top" title="csv" href="/export/branches/csv">
                                    <img src="assets/img/icons/excel.svg" alt="img">
                                </a>
                            </li>
                            <li>
                                <a data-bs-toggle="tooltip" data-bs-placement="top" title="print" onclick="window.print()">
                                    <img src="assets/img/icons/printer.svg" alt="img">
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table datanew">
                        <thead>
                            <tr>
                                <th>
                                    <label class="checkboxs">
                                        <input type="checkbox" id="select-all">
                                        <span class="checkmarks"></span>
                                    </label>
                                </th>
                                <th>Parent Restaurant</th>
                                <th data-i18n="table.owner">Owner Name</th>
                                <th data-i18n="table.name">Restaurant Name</th>
                                <th data-i18n="form.city">City</th>
                                <th data-i18n="table.address">Address</th>
                                <th data-i18n="table.email">Email</th>
                                <th data-i18n="table.mobile">Mobile</th>
                                <th data-i18n="table.action">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% branches.forEach(branch => { %>
                                <tr>
                                    <td>
                                        <label class="checkboxs">
                                            <input type="checkbox">
                                            <span class="checkmarks"></span>
                                        </label>
                                    </td>
                                    <td><%= branch.Parent_Rest %></td>
                                    <td><%= branch.ownerName %></td>
                                    <td><%= branch.restaurantName %></td>
                                    <td><%= branch.city %></td>
                                    <td><%= branch.address %></td>
                                    <td><%= branch.email %></td>
                                    <td><%= branch.mobile %></td>
                                    <td>
                                        <a class="me-3" href="javascript:void(0);" onclick="editBranch('<%= branch._id %>')">
                                            <img src="assets/img/icons/edit.svg" alt="img">
                                        </a>
                                        <a href="javascript:void(0);" onclick="confirmDeleteBranch('<%= branch._id %>')">
                                            <img src="assets/img/icons/delete.svg" alt="img">
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="assets/js/jquery-3.6.0.min.js"></script>
<script src="assets/js/feather.min.js"></script>
<script src="assets/js/jquery.slimscroll.min.js"></script>
<script src="assets/js/jquery.dataTables.min.js"></script>
<script src="assets/js/dataTables.bootstrap4.min.js"></script>
<script src="assets/js/bootstrap.bundle.min.js"></script>
<script src="assets/plugins/select2/js/select2.min.js"></script>
<script src="assets/plugins/sweetalert/sweetalert2.all.min.js"></script>
<script src="assets/plugins/sweetalert/sweetalerts.min.js"></script>
<script src="assets/js/script.js"></script>

<script>
    function editBranch(id) {
        fetch('/api/branches/' + id)
            .then(res => res.json())
            .then(branch => {
                const form = document.createElement('form');
                form.method = 'PUT';
                form.action = '/api/branches/' + id;

                const fields = ['Parent_Rest', 'ownerName', 'restaurantName', 'city', 'address', 'email', 'mobile'];
                const labels = ['Parent Restaurant', 'Owner Name', 'Restaurant Name', 'City', 'Address', 'Email', 'Mobile'];

                let html = '<div class="row">';
                fields.forEach((field, i) => {
                    html += `<div class="col-lg-3 col-sm-6 col-12">
                        <div class="form-group">
                            <label>${labels[i]}</label>
                            <input type="text" class="form-control" name="${field}" value="${branch[field] || ''}">
                        </div>
                    </div>`;
                });
                html += '</div>';

                Swal.fire({
                    title: 'Edit Branch',
                    html: html,
                    showCancelButton: true,
                    confirmButtonText: 'Update',
                    preConfirm: () => {
                        const data = {};
                        fields.forEach(f => {
                            data[f] = Swal.getPopup().querySelector(`[name="${f}"]`).value;
                        });
                        return fetch('/api/branches/' + id, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        }).then(res => {
                            if (res.ok) {
                                Swal.fire('Updated!', 'Branch has been updated.', 'success')
                                    .then(() => location.reload());
                            } else {
                                Swal.fire('Error!', 'Failed to update branch.', 'error');
                            }
                        });
                    }
                });
            });
    }

    function confirmDeleteBranch(id) {
        Swal.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch('/api/branches/' + id, { method: 'DELETE' })
                    .then(response => {
                        if (response.ok) {
                            Swal.fire('Deleted!', 'Branch has been deleted.', 'success')
                                .then(() => location.reload());
                        } else {
                            Swal.fire('Error!', 'Failed to delete branch.', 'error');
                        }
                    })
                    .catch(err => {
                        Swal.fire('Error!', 'Request failed: ' + err.message, 'error');
                    });
            }
        });
    }
</script>

</body>
</html>
