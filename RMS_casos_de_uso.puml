@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title RMS - Diagrama de Casos de Uso

actor Cliente
actor Proveedor
actor Cajero
actor "Dueño / Admin" as Admin

Admin --|> Cajero

rectangle "Restaurant Management System (RMS)" {

  package "POS" {
    usecase "Tomar Orden" as UC1
    usecase "Procesar Pago" as UC2
    usecase "Seleccionar Método\nDine In / Take Away / Online" as UC3
    usecase "Agregar Cliente\nRápido" as UC4
  }

  package "Inventario" {
    usecase "Ver Stock" as UC5
    usecase "Agregar Item" as UC6
    usecase "Editar Item" as UC7
    usecase "Ajustar Cantidad" as UC8
  }

  package "Compras" {
    usecase "Registrar Compra" as UC9
    usecase "Ver Historial" as UC10
  }

  package "Menú" {
    usecase "Agregar Plato" as UC11
    usecase "Editar Plato" as UC12
    usecase "Cambiar Disponibilidad" as UC13
  }

  package "Clientes" {
    usecase "Registrar Cliente" as UC14
    usecase "Ver Clientes" as UC15
    usecase "Ver Órdenes\nDel Cliente" as UC16
  }

  package "Gastos y Reportes" {
    usecase "Registrar Gasto" as UC17
    usecase "Generar Reportes\nPDF / CSV" as UC18
  }

  package "Sistema" {
    usecase "Iniciar Sesión" as UC19
    usecase "Cerrar Sesión" as UC20
    usecase "Ver Dashboard" as UC21
    usecase "Gestionar Perfil\nY Avatar" as UC22
    usecase "Cambiar Idioma\nES / EN" as UC23
    usecase "Ver Auditoría" as UC24
  }
}

' Cajero
Cajero --> UC1
Cajero --> UC2
Cajero --> UC3
Cajero --> UC4
Cajero --> UC5
Cajero --> UC19
Cajero --> UC20
Cajero --> UC21

' Admin (solo funciones exclusivas)
Admin --> UC6
Admin --> UC7
Admin --> UC8
Admin --> UC9
Admin --> UC10
Admin --> UC11
Admin --> UC12
Admin --> UC13
Admin --> UC14
Admin --> UC15
Admin --> UC16
Admin --> UC17
Admin --> UC18
Admin --> UC22
Admin --> UC23
Admin --> UC24

Cliente --> UC1
Cliente --> UC16

Proveedor --> UC9

@enduml