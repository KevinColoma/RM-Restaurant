<%- include('header') -%>

<div class="page-wrapper">
    <div class="content">
        <div class="page-header">
            <div class="page-title">
                <h4>Edit Item</h4>
                <h6>Update item details</h6>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <form id="edit-item-form">
                    <div class="row">
                        <div class="col-lg-3 col-sm-6 col-12">
                            <div class="form-group">
                                <label>Item Name</label>
                                <input type="text" name="item" id="item" value="<%= menu.item %>" required>
                            </div>
                        </div>
                        <div class="col-lg-3 col-sm-6 col-12">
                            <div class="form-group">
                                <label>Category</label>
                                <select class="select" name="category" id="category" required>
                                    <option value="">Choose Category</option>
                                    <option value="Veg" <%= menu.category === 'Veg' ? 'selected' : '' %>>Veg</option>
                                    <option value="Non-Veg" <%= menu.category === 'Non-Veg' ? 'selected' : '' %>>Non-Veg</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-3 col-sm-6 col-12">
                            <div class="form-group">
                                <label>Sub Category</label>
                                <select class="select" name="subCategory" id="subCategory" required>
                                    <option value="">Choose Sub Category</option>
                                    <option value="Starter" <%= menu.subCategory === 'Starter' ? 'selected' : '' %>>Starter</option>
                                    <option value="Main Course" <%= menu.subCategory === 'Main Course' ? 'selected' : '' %>>Main Course</option>
                                    <option value="Soup" <%= menu.subCategory === 'Soup' ? 'selected' : '' %>>Soup</option>
                                    <option value="Beverage" <%= menu.subCategory === 'Beverage' ? 'selected' : '' %>>Beverage</option>
                                    <option value="Salad" <%= menu.subCategory === 'Salad' ? 'selected' : '' %>>Salad</option>
                                    <option value="Dessert" <%= menu.subCategory === 'Dessert' ? 'selected' : '' %>>Dessert</option>
                                    <option value="Roti" <%= menu.subCategory === 'Roti' ? 'selected' : '' %>>Roti</option>
                                    <option value="Rice" <%= menu.subCategory === 'Rice' ? 'selected' : '' %>>Rice</option>
                                    <option value="Juice" <%= menu.subCategory === 'Juice' ? 'selected' : '' %>>Juice</option>
                                    <option value="Side Dish" <%= menu.subCategory === 'Side Dish' ? 'selected' : '' %>>Side Dish</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-3 col-sm-6 col-12">
                            <div class="form-group">
                                <label>Price</label>
                                <input type="number" name="price" id="price" step="0.01" min="0" value="<%= menu.price %>" required>
                            </div>
                        </div>
                        <div class="col-lg-12">
                            <button type="submit" class="btn btn-submit me-2">Update</button>
                            <a href="/getmenu" class="btn btn-cancel">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById("edit-item-form").addEventListener("submit", async function(event) {
        event.preventDefault();

        const item = document.getElementById("item").value;
        const category = document.getElementById("category").value;
        const subCategory = document.getElementById("subCategory").value;
        const price = document.getElementById("price").value;

        const data = {
            item,
            category,
            subCategory,
            price
        };

        try {
            const response = await fetch("/api/menu/<%= menu._id %>", {
                method: "PUT",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (response.ok) {
                console.log("Item updated successfully:", result);
                Swal.fire('Success!', 'Item updated successfully!', 'success')
                    .then(() => window.location.href = "/getmenu");
            } else {
                console.error("Error updating item:", result);
                Swal.fire('Error!', result.message || 'Failed to update item.', 'error');
            }
        } catch (err) {
            console.error("Request failed:", err);
            Swal.fire('Error!', 'Request failed: ' + err.message, 'error');
        }
    });
</script>

<script src="assets/js/jquery-3.6.0.min.js"></script>
<script src="assets/js/feather.min.js"></script>
<script src="assets/js/jquery.slimscroll.min.js"></script>
<script src="assets/js/jquery.dataTables.min.js"></script>
<script src="assets/js/dataTables.bootstrap4.min.js"></script>
<script src="assets/js/bootstrap.bundle.min.js"></script>
<script src="assets/plugins/select2/js/select2.min.js"></script>
<script src="assets/plugins/sweetalert/sweetalert2.all.min.js"></script>
<script src="assets/plugins/sweetalert/sweetalerts.min.js"></script>
<script src="assets/js/script.js"></script>
</body>
</html>
