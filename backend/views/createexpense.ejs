<%- include('header') -%>
<link rel="stylesheet" href="assets/plugins/select2/css/select2.min.css">
<link rel="stylesheet" href="assets/css/bootstrap-datetimepicker.min.css">
<link rel="stylesheet" href="assets/css/form-improvements.css">

<div class="page-wrapper">
    <div class="content">
        <div class="page-header">
            <div class="page-title">
                <h4 data-i18n="form.expense_title">Expense Add</h4>
                <h6 data-i18n="form.expense_sub">Add/Update Expenses</h6>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <form id="add-expense-form" novalidate>
                    <div class="row">
                        <!-- Expense Category -->
                        <div class="col-lg-3 col-sm-6 col-12">
                            <div class="form-group" id="category-group">
                                <label for="category" class="form-label" data-i18n="form.expense_category">Expense Category <span class="text-danger">*</span></label>
                                <select class="form-control custom-select" id="category" required>
                                    <option value="" disabled selected> expense category</option>
                                    <option value="supplies">Supplies</option>
                                    <option value="salaries">Salaries</option>
                                    <option value="utilities">Utilities</option>
                                    <option value="rent">Rent/Mortgage</option>
                                    <option value="insurance">Insurance</option>
                                    <option value="depreciation">Depreciation</option>
                                    <option value="labor">Labor Costs</option>
                                    <option value="marketing">Marketing and Advertising</option>
                                    <option value="maintenance">Maintenance and Repairs</option>
                                    <option value="technology">Technology</option>
                                    <option value="licenses">Licenses and Permits</option>
                                    <option value="miscellaneous">Miscellaneous</option>
                                    <!-- Add more categories as needed -->
                                </select>
                            </div>
                        </div>
                        
                        <!-- Expense Date -->
                        <div class="col-lg-3 col-sm-6 col-12">
                            <div class="form-group" id="expenseDate-group">
                                <label for="expenseDate" class="form-label" data-i18n="form.expense_date">Expense Date <span class="text-danger">*</span></label>
                                <input type="date" id="expenseDate" class="form-control" required>
                            </div>
                        </div>

                        <!-- Amount -->
                        <div class="col-lg-3 col-sm-6 col-12">
                            <div class="form-group" id="amount-group">
                                <label for="amount" class="form-label" data-i18n="form.amount">Amount <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <input type="number" id="amount" class="form-control" step="0.01" min="0.01" placeholder="0.00" required>
                                    <div class="input-group-append">
                                        <span class="input-group-text">$</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Reference No. -->
                        <div class="col-lg-3 col-sm-6 col-12">
                            <div class="form-group" id="invoiceNumber-group">
                                <label for="invoiceNumber" class="form-label">Invoice / Reference No.</label>
                                <input type="text" id="invoiceNumber" class="form-control" placeholder="Optional">
                            </div>
                        </div>

                        <!-- Expense for -->
                        <div class="col-lg-12">
                            <div class="form-group" id="vendor-group">
                                <label for="vendor" class="form-label" data-i18n="form.vendor">Expense for (vendor/employee)</label>
                                <input type="text" id="vendor" class="form-control" placeholder="Who did you pay?">
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="col-lg-12">
                            <div class="form-group" id="description-group">
                                <label for="description" class="form-label" data-i18n="form.description">Description</label>
                                <textarea class="form-control" id="description" rows="3" placeholder="What was this expense for?"></textarea>
                            </div>
                        </div>
                        
                        <!-- Buttons -->
                        <div class="col-lg-12">
                            <button type="submit" id="submit-btn" class="btn btn-primary me-2" data-i18n="form.submit">Submit</button>
                            <a href="/getexpense" class="btn btn-secondary" data-i18n="form.cancel">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</div>
<script>
    // Form utilities
    function disableSubmit(btn) {
        btn.disabled = true;
        btn.classList.add('btn-loading');
        btn.setAttribute('aria-busy', 'true');
        const originalText = btn.textContent;
        btn.innerHTML = '<span class="spinner-sm"></span> ' + originalText;
        return originalText;
    }

    function enableSubmit(btn, originalText = 'Submit') {
        btn.disabled = false;
        btn.classList.remove('btn-loading');
        btn.removeAttribute('aria-busy');
        btn.textContent = originalText;
    }

    function showFieldError(fieldId, message) {
        const field = document.getElementById(fieldId);
        if (!field) return;
        field.classList.add('is-invalid');
        field.setAttribute('aria-invalid', 'true');
        let errorEl = field.parentElement.querySelector('.invalid-feedback');
        if (!errorEl) {
            errorEl = document.createElement('div');
            errorEl.className = 'invalid-feedback d-block';
            field.parentElement.appendChild(errorEl);
        }
        errorEl.textContent = message;
    }

    function clearFieldError(fieldId) {
        const field = document.getElementById(fieldId);
        if (!field) return;
        field.classList.remove('is-invalid');
        field.removeAttribute('aria-invalid');
        const errorEl = field.parentElement.querySelector('.invalid-feedback');
        if (errorEl) errorEl.remove();
    }

    function clearAllErrors(form) {
        form.querySelectorAll('.is-invalid').forEach(field => {
            clearFieldError(field.id);
        });
    }

    const form = document.getElementById("add-expense-form");
    const submitBtn = document.getElementById("submit-btn");

    form.addEventListener("submit", async function(event) {
        event.preventDefault();

        // Limpiar errores previos
        clearAllErrors(form);

        // Obtener valores
        const category = document.getElementById("category").value;
        const expenseDate = document.getElementById("expenseDate").value;
        const amount = document.getElementById("amount").value;
        const invoiceNumber = document.getElementById("invoiceNumber").value;
        const vendor = document.getElementById("vendor").value;
        const description = document.getElementById("description").value;

        let hasErrors = false;

        // Validación de categoría
        if (!category) {
            showFieldError("category", "Please select an expense category");
            hasErrors = true;
        }

        // Validación de fecha
        if (!expenseDate) {
            showFieldError("expenseDate", "Please select an expense date");
            hasErrors = true;
        }

        // Validación de monto
        const numAmount = Number(amount);
        if (!amount || isNaN(numAmount) || numAmount <= 0) {
            showFieldError("amount", "Amount must be a valid number greater than 0.01");
            hasErrors = true;
        }

        // Si hay errores, no continuar
        if (hasErrors) {
            Swal.fire('Validation Error', 'Please fill in all required fields correctly.', 'warning');
            return;
        }

        // Deshabilitar botón y mostrar spinner
        const originalText = disableSubmit(submitBtn);

        const data = {
            category,
            expenseDate,
            amount,
            invoiceNumber,
            vendor,
            description
        };

        try {
            const response = await fetch("/api/addexpense", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (response.ok) {
                // Éxito
                await Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: 'Expense added successfully!',
                    showConfirmButton: true,
                    timer: 2000
                });

                // Limpiar formulario
                form.reset();
                clearAllErrors(form);

                // Re-habilitar botón
                enableSubmit(submitBtn, originalText);
            } else {
                // Error del servidor
                const message = result.message || 'Failed to save expense. Please try again.';
                Swal.fire('Error', message, 'error');
                enableSubmit(submitBtn, originalText);
            }
        } catch (err) {
            console.error("Request failed:", err);
            Swal.fire('Error', 'Network error. Please check your connection and try again.', 'error');
            enableSubmit(submitBtn, originalText);
        }
    });

    // Validación en tiempo real: limpiar error cuando el usuario empieza a escribir
    ['category', 'expenseDate', 'amount'].forEach(fieldId => {
        const field = document.getElementById(fieldId);
        field.addEventListener('change', function() {
            clearFieldError(fieldId);
        });
        field.addEventListener('input', function() {
            clearFieldError(fieldId);
        });
    });
</script>






<script src="assets/js/jquery-3.6.0.min.js"></script>

<script src="assets/js/feather.min.js"></script>

<script src="assets/js/jquery.slimscroll.min.js"></script>

<script src="assets/js/jquery.dataTables.min.js"></script>
<script src="assets/js/dataTables.bootstrap4.min.js"></script>

<script src="assets/js/bootstrap.bundle.min.js"></script>

<script src="assets/plugins/select2/js/select2.min.js"></script>

<script src="assets/js/moment.min.js"></script>
<script src="assets/js/bootstrap-datetimepicker.min.js"></script>

<script src="assets/plugins/sweetalert/sweetalert2.all.min.js"></script>
<script src="assets/plugins/sweetalert/sweetalerts.min.js"></script>

<script src="assets/js/script.js"></script>
</body>
</html>