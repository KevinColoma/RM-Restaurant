    subgraph Back["Backend (Node.js / Express)"]
        App["app.js"]
        Routes["routes/"]
        Middleware["middleware/"]
        Controllers["controllers/"]
        Models["models/"]
        Utils["utils/"]
    end

    subgraph DB["Persistencia"]
        Mongo[("MongoDB 7")]
    end

    subgraph Ext["Servicios Externos"]
        PDF["PDFKit"]
        CSV["json2csv"]
        Upload["multer"]
