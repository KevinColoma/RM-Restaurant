    style title fill:none,stroke:none,font-weight:bold,font-size:18px

    %% --- PAQUETES Y COMPONENTES ---
    
    subgraph Front["Frontend (EJS / jQuery)"]
        Views["Vistas EJS"]
        JS["assets/js"]
        CSS["assets/css"]
